---
import Base from "../layouts/Base.astro";
---

<Base title="Guo Qi (郭奇)">
  <section>
    <!-- TODO: replace bio with your own -->
    <h1>Guo Qi <span class="zh-name">郭奇</span></h1>
    <p class="tagline">
      A son, a husband, a father, a PhD, and a life-long learner.
    </p>
    <p>
      A short bio: who you are, what you work on, and what you care about.
      Two or three sentences is plenty — link to anything worth linking to,
      like <a href="https://github.com/hotpotgot">your GitHub</a> or a
      project you're proud of.
    </p>
  </section>
</Base>

<style>
  .tagline {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .zh-name {
    font-family: "Xingkai SC", "STXingkai", "华文行楷", "Zhi Mang Xing",
      "Kaiti SC", KaiTi, cursive;
    font-weight: normal;
    font-size: 1.15em;
  }
</style>
