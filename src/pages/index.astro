---
import Base from "../layouts/Base.astro";
---

<Base title="Your Name">
  <section>
    <!-- TODO: replace name, title, and bio with your own -->
    <h1>Your Name</h1>
    <p class="tagline">Your title or one-line description goes here.</p>
    <p>
      A short bio: who you are, what you work on, and what you care about.
      Two or three sentences is plenty — link to anything worth linking to,
      like <a href="https://github.com/yourhandle">your GitHub</a> or a
      project you're proud of.
    </p>
  </section>
</Base>

<style>
  .tagline {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
</style>
